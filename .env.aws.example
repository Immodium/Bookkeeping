NODE_ENV=production
HOST=0.0.0.0
PORT=3002

# URL/Origin
CLIENT_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com
CORS_CREDENTIALS=true
VITE_API_URL=https://app.example.com

# Runtime DB mode for AWS baseline
DB_ENGINE=sqlite
DB_PATH=/mnt/app-data/data/slimbooks.db
DB_BACKUP_PATH=/mnt/app-data/data/backups

# Optional Postgres fields (for future runtime cutover)
DATABASE_URL=
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_SSL=true
PG_MAX_CONNECTIONS=20

# Upload/object storage
UPLOAD_PATH=/mnt/app-data/uploads
STORAGE_PROVIDER=s3
STORAGE_LOCAL_BASE_PATH=/mnt/app-data/uploads
STORAGE_PUBLIC_BASE_URL=/uploads
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Core auth secrets
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=

# Optional secret bundle if injected from Secrets Manager
APP_SECRETS_BUNDLE=

# Security/perf
ENABLE_SAMPLE_DATA=false
ENABLE_DEBUG_ENDPOINTS=false
MAX_FILE_SIZE=10485760
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
