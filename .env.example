# Slimbooks Environment Configuration
# Copy this file to .env and update the values for your deployment

# Server Configuration
PORT=3002
HOST=localhost

# HTTPS Configuration
ENABLE_HTTPS=false
SSL_KEY_PATH=certs/server.key
SSL_CERT_PATH=certs/server.crt
ENFORCE_HTTPS_REDIRECT=false

# Frontend Configuration
VITE_API_URL=http://localhost:3002
VITE_APP_NAME=Slimbooks
CLIENT_URL=http://localhost:8080

# Security Configuration - GENERATE YOUR OWN SECRETS
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# REQUIRED in production: must be set and at least 32 characters
JWT_SECRET=your-secret-key-here-replace-with-random-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-here-replace-with-random-64-chars
# REQUIRED in production: must be set and at least 32 characters
SESSION_SECRET=your-session-secret-key-here-replace-with-random-64-chars

# Token Expiration (in milliseconds)
ACCESS_TOKEN_EXPIRY=7200000
REFRESH_TOKEN_EXPIRY=604800000
EMAIL_TOKEN_EXPIRY=86400000
PASSWORD_RESET_EXPIRY=3600000

# Database Configuration
# SQLite (default when DATABASE_URL is not set)
DB_PATH=./data/slimbooks.db
DB_BACKUP_PATH=./data/backups

# PostgreSQL (optional - set DATABASE_URL to switch from SQLite to PostgreSQL)
# When set, PostgreSQL is used instead of SQLite.
# Example: postgresql://user:password@localhost:5432/slimbooks
# REQUIRED in production when using PostgreSQL.
# DATABASE_URL=

# PostgreSQL connection pool tuning (used when DATABASE_URL is set)
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# CORS Configuration
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (optional - for email features)
# Provider can be "smtp" or "sendgrid"
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp

# SMTP configuration (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@slimbooks.app

# SendGrid configuration (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@slimbooks.app

# Node Environment
NODE_ENV=development

# SaaS/Hosted mode controls
SAAS_MODE=false
ALLOW_DATABASE_IMPORT_EXPORT=true
CRON_JOB_SECRET=
BILLING_WEBHOOK_SECRET=

# Stripe Configuration (required for Stripe checkout/portal/webhooks)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# REQUIRED in production when STRIPE_SECRET_KEY is set
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — one per paid plan (e.g. from your Stripe dashboard)
STRIPE_PRICE_STARTER=

# Application URL (used in emails and links)
APP_URL=http://localhost:5173

# Static file serving
# Set to false when using CloudFront/S3 for static assets (recommended in production)
SERVE_STATIC_FILES=true

# Logging
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
